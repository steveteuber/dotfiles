[user]
  name = {{ .name }}
  email = {{ onepasswordRead "op://Private/GitHub Signing Key/email" "my" }}
  signingkey = {{ onepasswordRead "op://Private/GitHub Signing Key/public_key" "my" }}

[core]
  excludesfile = ~/.gitignore

[gpg]
  format = ssh

[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[commit]
  template = {{ .chezmoi.homeDir }}/.gitmessage
  gpgsign = true

[tag]
  gpgsign = true

[pull]
  rebase = true

[push]
  autosetupremote = true

[rebase]
  autostash = true

[advice]
  skippedcherrypicks = false

[help]
  autocorrect = 10

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

{{ if .idealo -}}
[includeIf "gitdir:~/Projects/idealo/"]
  path = ~/.gitconfig-idealo
{{ end -}}
